# =====================================================
# ArkClaw SaaS Widget — 环境变量模板
# 复制为 .env 后填入真实值
# =====================================================

# ── 火山引擎 ArkClaw（必填） ──
VOLC_ACCESS_KEY_ID=AKLTxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VOLC_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ARKCLAW_REGION=cn-beijing
ARKCLAW_SPACE_ID=
ARKCLAW_INSTANCE_ID=

# ── 飞书 OAuth（如果使用 lark 模式则必填） ──
# 重定向 URL 需要在飞书开发者后台配置：
#   http://127.0.0.1:8000/auth/lark/callback
LARK_APP_ID=cli_xxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LARK_REDIRECT_URI=http://127.0.0.1:8000/auth/lark/callback

# ── 自家 Session JWT（必填，强随机串） ──
SESSION_JWT_SECRET=please-replace-with-32+-char-random-string
SESSION_JWT_TTL=86400

# ── SaaS JWT 校验（外部 SaaS 接入时填一个） ──
# HS256：填 SAAS_JWT_SECRET
# RS256：填 SAAS_JWT_PUBLIC_KEY
SAAS_JWT_ALGORITHM=HS256
SAAS_JWT_SECRET=
SAAS_JWT_PUBLIC_KEY=
SAAS_JWT_ISSUER=
SAAS_JWT_AUDIENCE=

# ── FastAPI 服务 ──
HOST=127.0.0.1
PORT=8000
CORS_ORIGINS=*
